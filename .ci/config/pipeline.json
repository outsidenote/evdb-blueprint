{
  "confidence": {
    "weights": {
      "verify_pass": 35,
      "test_pass": 35,
      "no_todos_remaining": 10,
      "no_repair_needed": 10,
      "repair_succeeded": 5,
      "diff_boundary_clean": 5,
      "scan_session_clean": 5,
      "token_anomaly_penalty": -5,
      "turn_anomaly_penalty": -5
    },
    "thresholds": {
      "token_anomaly": 80000,
      "turn_anomaly": 30
    },
    "bands": {
      "HIGH": 80,
      "MEDIUM": 50,
      "LOW": 20,
      "BLOCKED": 0
    },
    "recommendations": {
      "HIGH": "Ready for review",
      "MEDIUM": "Review with attention to flagged areas",
      "LOW": "Significant concerns — manual inspection required",
      "BLOCKED": "Do not merge — critical failures unresolved"
    }
  },
  "repair": {
    "levels": {
      "L1": {
        "name": "deterministic",
        "ai": false,
        "max_files": -1,
        "max_turns": 0,
        "max_budget_usd": 0.0
      },
      "L2": {
        "name": "bounded_ai",
        "ai": true,
        "model": "opus",
        "max_files": 3,
        "max_turns": 10,
        "max_budget_usd": 2.00
      },
      "L3": {
        "name": "expanded_ai",
        "ai": true,
        "model": "opus",
        "max_files": 3,
        "max_turns": 20,
        "max_budget_usd": 5.00
      },
      "L4": {
        "name": "human_escalation",
        "ai": false,
        "max_files": 0,
        "max_turns": 0,
        "max_budget_usd": 0.0
      }
    },
    "strategies": {
      "import_error":           { "deterministic": true,  "allowed_files": ["*.ts"] },
      "type_error":             { "deterministic": true,  "allowed_files": ["command.ts", "gwts.ts", "commandHandler.ts", "state.ts"] },
      "path_error":             { "deterministic": true,  "allowed_files": ["*"] },
      "predicate_mismatch":     { "deterministic": false, "allowed_files": ["gwts.ts"] },
      "missing_handler_branch": { "deterministic": false, "allowed_files": ["commandHandler.ts"] },
      "verification_failure":   { "deterministic": false, "allowed_files": ["gwts.ts", "commandHandler.ts", "adapter.ts"] },
      "test_failure":           { "deterministic": false, "allowed_files": ["gwts.ts", "commandHandler.ts", "index.ts", "enrichment.ts"] },
      "lint_error":             { "deterministic": false, "allowed_files": ["*.ts"] }
    }
  },
  "cost": {
    "per_slice_warning_usd": 5.00,
    "per_run_hard_limit_usd": 15.00
  },
  "audit": {
    "retention_days": 90,
    "metrics_retention_days": 90
  },
  "discussions": {
    "enabled": true,
    "category_name": "Spec Clarifications",
    "report_category_name": "Usage Reports",
    "link_in_pr": true
  },
  "review_checklists": {
    "STATE_CHANGE": [
      "Predicate logic in `gwts.ts` matches domain rules",
      "All GWT spec scenarios have matching handler branches",
      "Event fields are complete — all command fields flow through",
      "Rejection paths emit correct error messages"
    ],
    "STATE_VIEW": [
      "SQL type casts match TS types (numeric → REAL/INT)",
      "COALESCE used for accumulation fields (avoid null arithmetic)",
      "DateTime fields use `toISOString()` for storage",
      "Projection handles all consumed events"
    ],
    "PROCESSOR": [
      "Trigger conditions match spec event types",
      "Idempotent — handles duplicate events safely",
      "Error handling doesn't leave inconsistent state",
      "Output command fields correctly mapped from input event"
    ],
    "ENRICHMENT": [
      "Formula steps match spec (verify intermediate calculations)",
      "Edge cases: zero, negative, null, boundary values handled",
      "Rounding and precision match business requirements",
      "All formula inputs sourced from correct fields"
    ],
    "_always": [
      "Tests cover edge cases, not just happy path"
    ]
  }
}
