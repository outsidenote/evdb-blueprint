{
  "name": "evdb-blueprint",
  "version": "1.0.0",
  "description": "Withdrawal Approval event modeling slice — blueprint app using eventualize-js",
  "main": "./dist/server.js",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "rebuild": "npm run clean && npm run build",
    "start": "node dist/server.js",
    "dev": "node --import tsx src/server.ts",
    "test:unit": "node --import tsx --test 'src/tests/unit.test.ts'",
    "test:behaviour": "node --import tsx --test 'src/tests/behaviour.test.ts'",
    "test": "node --import tsx --test 'src/tests/**/*.test.ts'"
  },
  "dependencies": {
    "@eventualize/core": "^2.1.0",
    "@eventualize/postgres-storage-adapter": "^2.1.0",
    "@eventualize/relational-storage-adapter": "^2.1.0",
    "@eventualize/types": "^2.0.0",
    "@prisma/adapter-pg": "7.3.0",
    "@prisma/client": "7.3.0",
    "express": "^4.21.0",
    "pg": "^8.0.0",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.0",
    "rimraf": "^6.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
